{
  "name": "tutuca",
  "version": "0.9.23",
  "type": "module",
  "description": "Zero-dependency SPA framework with immutable state and virtual DOM",
  "main": "./dist/tutuca.js",
  "module": "./dist/tutuca.js",
  "exports": {
    ".": "./dist/tutuca.js",
    "./dev": "./dist/tutuca-dev.js",
    "./extra": "./dist/tutuca-extra.js",
    "./cli": "./dist/tutuca-cli.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "tutuca": "./dist/tutuca-cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dist": "bun scripts/dist.js",
    "dist-immutable": "bun scripts/dist-immutable.js",
    "dist-all": "bun run dist-immutable && bun run dist",
    "release": "bun run dist-all && npm publish --access public",
    "release-dry": "bun run dist-all && npm publish --dry-run",
    "test": "bun test test/*.test.js",
    "test-watch": "bun test --watch test/*.test.js",
    "format": "bunx @biomejs/biome format --write src test/*.js",
    "lint": "bunx @biomejs/biome lint src test/*.js",
    "lint-fix": "bunx @biomejs/biome lint --write src test/*.js",
    "fix": "bunx @biomejs/biome check --write src test/*.js",
    "tutuca": "bun tools/tutuca.js",
    "stresstest": "bun scripts/stresstest.js",
    "smoke-test": "bun tools/tutuca.js ./test/todo.js doctor && bun tools/tutuca.js ./test/json.js doctor"
  },
  "sideEffects": false,
  "files": [
    "dist/tutuca.js",
    "dist/tutuca.min.js",
    "dist/tutuca-dev.js",
    "dist/tutuca-dev.min.js",
    "dist/tutuca-extra.js",
    "dist/tutuca-extra.min.js",
    "dist/tutuca-cli.js"
  ],
  "dependencies": {
    "jsdom": "^28.0.0 || ^29.0.0"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    }
  },
  "keywords": [
    "frontend",
    "framework",
    "immutable",
    "virtual-dom"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marianoguerra/tutuca.git"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Mariano Guerra",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/marianoguerra/tutuca/issues"
  },
  "homepage": "https://github.com/marianoguerra/tutuca#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "fast-check": "^4.7.0",
    "prettier": "^3.8.3"
  }
}
